#!/usr/bin/env bash
# gnutil - Fast GNU tools via nix (no profile, cached binaries)
#
# Use as a symlink (gsed, gawk, …) or directly:
#   gnutil          — list all supported tools
#   gnutil CMD …   — install and run GNU CMD (thereafter you can use gCMD)

set -euo pipefail

# tool → nixpkgs attribute
PKG_MAP="
sed     gnused
awk     gawk
grep    gnugrep
fgrep   gnugrep
egrep   gnugrep
tar     gnutar
make    gnumake
date    coreutils
cp      coreutils
ls      coreutils
rm      coreutils
mv      coreutils
du      coreutils
stat    coreutils
whoami  coreutils
sort    coreutils
head    coreutils
tail    coreutils
cut     coreutils
tr      coreutils
"

localbin="${GNUTIL_LOCALBIN:-$HOME/Local/bin}"
linkdir="${GNUTIL_LINKDIR:-$HOME/Local/share/gnutil}"

# Ensures the nix package for CMD is built and prints the path to the binary.
# All user-visible output goes to stderr so the printed path is clean.
ensure_pkg() {
    local cmd="$1"
    local pkg link cmdlink
    pkg=$(awk -v c="$cmd" '$1==c{print $2; exit}' <<< "$PKG_MAP")
    [[ -n "$pkg" ]] || { echo "gnutil: unknown tool '$cmd'" >&2; return 127; }
    link="${linkdir}/${cmd}"
    cmdlink="${link}/bin/${cmd}"
    if [[ ! -x "$cmdlink" ]]; then
        echo "gnutil: building $pkg for $cmd (first time only)..." >&2
        mkdir -p "$linkdir"
        nix-build --quiet -A "$pkg" -o "$link" '<nixpkgs>' 1>&2
    fi
    echo "$cmdlink"
}

basename="${0##*/}"

if [[ "$basename" == "gnutil" ]]; then
    if [[ $# -eq 0 ]]; then
        echo "Supported GNU tools (gnutil CMD to install, then use gCMD):"
        awk 'NF==2 {printf "  g%-10s %s\n", $1, $2}' <<< "$PKG_MAP"
        exit 0
    fi
    cmd="${1#g}"
    pkg=$(awk -v c="$cmd" '$1==c{print $2; exit}' <<< "$PKG_MAP")
    [[ -n "$pkg" ]] || { echo "gnutil: unknown tool '$cmd'" >&2; exit 127; }
    ensure_pkg "$cmd" >/dev/null
    symlink="${localbin}/g${cmd}"
    [[ -e "$symlink" || -L "$symlink" ]] && { echo "gnutil: $symlink already exists" >&2; exit 1; }
    mkdir -p "$localbin"
    ln -s gnutil "$symlink"
    echo "gnutil: installed g${cmd}" >&2
    exit 0
fi

cmd="${basename#g}"
cmdlink=$(ensure_pkg "$cmd") || exit $?
exec "$cmdlink" "$@"
