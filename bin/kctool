#!/usr/bin/env bash
#
# A simple script to interactively work with kubectl

# Note: This script targets Bash v3.2 as that is the default on MacOS.

# Default things/kind to list if no argument is given
# ALLMORE is a play on "all" not really being "all"
ALLMORE="all,ingress,secret"

REQUIRED_TOOLS="kubectl jq"

kobj=()

# Remove replicasets where desired, current, & ready are all 0
clean_replicaset.apps() {
  local res="$2"
  local ns="$1"
  # shellcheck disable=SC2155
  local info=$(kubectl get "$res" -n "$ns" --no-headers)

  # shellcheck disable=SC2086
  set -- $info

  if [[ "$2" == 0 && "$3" == 0 && "$4" == 0 ]]; then
#     echo "! Deleting: $res @$ns"
    if confirm_action "[$res]"; then
      kubectl delete "$res" -n "$ns"
    fi
  fi
}

# Remove pods where 0/x and status "dead"
clean_pod() {
  local res="$2"
  local ns="$1"
  # shellcheck disable=SC2155
  local info=$(kubectl get "$res" -n "$ns" --no-headers)

  local dead_status="Error ContainerStatusUnknown"

  # NAME READY STATUS RESTARTS AGE
  # shellcheck disable=SC2086
  set -- $info

  if [[ "$2" == 0/* && "$dead_status" =~ $3 ]]; then
#     echo "! Deleting: $res @$ns"
    if confirm_action "[$res]"; then
      kubectl delete "$res" -n "$ns"
    fi
  fi
}

do_C() {
  local ns="$1"; shift
  ptitle "CLEAN $# (objects) in $ns"
  for obj in "$@"; do
    local kind="${obj%%/*}"
    if declare -f "clean_$kind" >/dev/null; then
      "clean_$kind" "$ns" "$obj"
    else
      echo "! No clean function for kind: $kind ($obj)"
    fi
  done
}

do_D() {
  local ns="$1"; shift
  ptitle "DESCRIBE $2 @$ns"
  kubectl describe -n "$ns" "$@"
  pause4user
}

do_E() {
  local ns="$1"; shift

  for obj in "$@"; do
    if [[ "$obj" == "all" || "$obj" != */* ]]; then
      ptitle "EVENTS (all objects) @$ns"
      kubectl get events -n "$ns" --sort-by=.metadata.creationTimestamp
      return
    fi

    # shellcheck disable=SC2155
    local kind=$(get_actual_kind "$ns" "$obj")
    local name="${obj##*/}"

    if [[ -z "$kind" || "$kind" == "null" ]]; then
      echo "! Could not determine kind for $obj in namespace $ns"
      continue
    fi

    ptitle "EVENTS for $kind/$name @$ns"
    kubectl get events -n "$ns" \
      --field-selector "involvedObject.name=$name,involvedObject.kind=$kind" \
      --sort-by=.metadata.creationTimestamp
  done
  pause4user
}

pick_container() {
  # Usage: pick_container <ns> <kind/name>  → prints "-c <name>" or "" (single/non-pod)
  local ns="$1" obj="$2"
  [[ "${obj%%/*}" != pod* ]] && echo "" && return
  local containers
  containers=$(kubectl get "$obj" -n "$ns" \
    -o jsonpath='{range .spec.containers[*]}{.name}{"\n"}{end}' 2>/dev/null)
  local count
  count=$(printf '%s\n' "$containers" | grep -c .)
  if [[ "$count" -le 1 ]]; then
    echo ""
    return
  fi
  echo "Multiple containers in $obj:"
  local i=0
  while IFS= read -r c; do
    printf "  %d: %s\n" "$i" "$c"
    ((i++))
  done <<<"$containers"
  read -rp "Container [0]: " choice
  choice="${choice:-0}"
  local chosen
  chosen=$(printf '%s\n' "$containers" | sed -n "$((choice+1))p")
  echo "-c $chosen"
}

do_F() {
  local ns="$1"; shift
  for obj in "$@"; do
    local copt
    copt=$(pick_container "$ns" "$obj")
    ptitle "FOLLOW $obj @$ns"
    # shellcheck disable=SC2086
    follow_wait "Logs ($obj)" kubectl logs "$obj" -f -n "$ns" $copt
  done
}

# Maybe switch focus to the obj gotten here?
do_G() {
  local ns="$1"; shift
  ptitle "GET $2 @$ns"
  kubectl get -n "$ns" "$@"
  pause4user
}

do_H() {
  ptitle "HELP"
  cat <<_EOM_
Enter one letter followed by a number. e.g. A12   (not case-sensitive)

The number (#) corresponds to a listed K8s object index (as given prior to the prompt).
This may be a range ("#-#" -> "12-34") - Consecutive objects from the same NS will be grouped.
<#> -> Number is required | [#] -> Number is optional | (#) -> Number is ignored

The letter can be one of:
 - C -> Clean <#> - Only remove if orphaned/unused
 - D -> Describe <#>
 - E -> (recent) Events [#]
 - F -> Follow log <#>   (press Return to stop)
 - G -> (plain) Get <#>
 - H -> (this) Help (#)
 - I -> Info (get wide) <#>
 - K -> Kick (rollout restart) <#>
 - L -> Logs <#>
 - P -> Port-forward <#>   (press Return to stop)
 - Q -> Quit (#)
 - R -> Remove (Delete) <#>
 - S -> Shell <#>
 - T -> Trail (follow new events) [#]   (press Return to stop)
 - U -> Usage (top) [#]
 - W -> Watch (get every 6s) <#>
 - X -> Set namespace / kind [#]
 - Y -> Get YAML <#>
 - Z -> Get YAML but try to b64 decode values <#>

_EOM_
  pause4user
}

do_I() {
  local ns="$1"; shift
  ptitle "INFO $2 @$ns"
  kubectl get -o wide -n "$ns" "$@"
  pause4user
}

do_K() {
  local ns="$1"; shift
  ptitle "KICK (rollout restart) $# object(s) @$ns"
  if confirm_action "[$*]" "rollout restart"; then
    kubectl rollout restart -n "$ns" "$@"
  fi
  pause4user
}

do_L() {
  local ns="$1"; shift
  for obj in "$@"; do
    local copt
    copt=$(pick_container "$ns" "$obj")
    ptitle "LOGS $obj @$ns"
    # shellcheck disable=SC2086
    kubectl logs "$obj" -n "$ns" $copt
  done
  pause4user
}

do_P() {
  local ns="$1"; shift
  local obj="$1"
  ptitle "PORT-FORWARD $obj @$ns"
  read -rp "Ports (local:remote or just port): " ports
  if [[ -z "$ports" ]]; then
    echo "! No ports specified."
    pause4user
    return
  fi
  # shellcheck disable=SC2086
  follow_wait "Port-forward ($obj $ports)" kubectl port-forward "$obj" $ports -n "$ns"
}

do_Q() {
  exit 0
}

do_R() {
  local ns="$1"; shift
  ptitle "REMOVE $# (objects) in @$ns"
  if confirm_action "[$*]"; then
    kubectl delete -n "$ns" "$@"
  fi
}

do_S() {
  local ns="$1"; shift
  for obj in "$@"; do
    local copt
    copt=$(pick_container "$ns" "$obj")
    ptitle "SHELL $obj @$ns"
    # Can't know what shell is available, assume at least 'sh', prefer bash (if there)
    # shellcheck disable=SC2086
    kubectl exec "$obj" -n "$ns" -it $copt -- sh -c 'bash -l || dash -l || sh -l || sh'
  done
}

do_T() {
  local ns="$1"; shift

  for obj in "$@"; do
    if [[ "$obj" == "all" || "$obj" != */* ]]; then
      ptitle "TRAIL EVENTS (all objects) @$ns"
      follow_wait "Events (@$ns)" kubectl get events -n "$ns" --watch --sort-by=.metadata.creationTimestamp
    else
      # shellcheck disable=SC2155
      local kind=$(get_actual_kind "$ns" "$obj")
      local name="${obj##*/}"

      if [[ -z "$kind" || "$kind" == "null" ]]; then
        echo "! Could not determine kind for $obj in namespace $ns"
        continue
      fi

      ptitle "TRAIL EVENTS for $kind/$name @$ns"
      follow_wait "Events ($kind/$name)" \
        kubectl get events -n "$ns" \
        --field-selector "involvedObject.name=$name,involvedObject.kind=$kind" \
        --watch
    fi
  done
}

do_W() {
  local ns="$1"; shift
  local OK=0
  while [ "$OK" -eq 0 ]; do
    clear
    ptitle "WATCH #$# @$ns - $(date)"
    kubectl get -o wide -n "$ns" "$@"
    OK=$?
    echo ""
    read -t 6 -r -p "[Press Return to stop]" line && break
  done
}

do_U() {
  local ns="$1"; shift

  if [[ "$#" -eq 0 || "$1" == "$WHAT" ]]; then
    ptitle "USAGE (top pods) @${ns:-ALL}"
    if [[ -n "$ns" ]]; then
      kubectl top pods -n "$ns"
    else
      kubectl top pods --all-namespaces
    fi
    pause4user
    return
  fi

  for obj in "$@"; do
    local kind="${obj%%/*}"
    local name="${obj##*/}"

    if [[ "$kind" == pod* ]]; then
      ptitle "USAGE $obj @$ns"
      kubectl top pod "$name" -n "$ns"
    elif [[ "$kind" == node* ]]; then
      ptitle "USAGE $obj"
      kubectl top node "$name"
    else
      local selector
      selector=$(kubectl get "$obj" -n "$ns" -o json 2>/dev/null \
        | jq -r '.spec.selector.matchLabels | to_entries | map(.key+"="+.value) | join(",")')
      if [[ -n "$selector" && "$selector" != "null" ]]; then
        ptitle "USAGE pods for $obj @$ns"
        kubectl top pods -n "$ns" -l "$selector"
      else
        echo "! Could not get pod selector for $obj"
      fi
    fi
  done
  pause4user
}

do_X() {
  local ns="$1"; shift
  local last="${*: -1}"

  # With an object arg: focus kind+ns on that object
  if [[ "$last" == */* ]]; then
    local kind="${last%%/*}"
    setup_ns "$ns"
    WHAT="$kind"
    echo "! Focused on kind: $WHAT  namespace: ${NAMESPACE:-<ALL>}"
    return
  fi

  # No object: interactive prompts, Enter keeps current value
  ptitle "Set Namespace / Kind"
  read -rp "Namespace [${NAMESPACE:-<ALL>}]: " ns_input
  [[ -n "$ns_input" ]] && setup_ns "$ns_input"

  read -rp "Kind [${WHAT}]: " kind_input
  if [[ -n "$kind_input" ]]; then
    WHAT="$kind_input"
    echo "! Kind is now: $WHAT"
  fi
}

do_Y() {
  local ns="$1"; shift
  ptitle "YAML $2 @$ns"
  kubectl get -o yaml -n "$ns" "$@"
  pause4user
}

do_Z() {
  local ns="$1"; shift
  for obj in "$@"; do
    ptitle "REVEAL $obj @$ns"
    kubectl get -n "$ns" "$obj" -o yaml 2>/dev/null | while IFS= read -r line; do
      echo "$line"
      if [[ "$line" =~ ^([[:space:]]*[^:#]+:[[:space:]])([^[:space:]].+)$ ]]; then
        local pad="${BASH_REMATCH[1]}"  
        local val="${BASH_REMATCH[2]}"
        if is_base64 "$val"; then
          local decoded
          decoded=$(base64 --decode <<< "$val" 2>/dev/null)
          pad="${pad%%:*}"  # leading spaces + key name, up to (not incl.) the colon
          printf '%s^- b64 decoded: %s\n' "${pad//?/ }" "$decoded"
        fi
      fi
    done
  done
  pause4user
}

is_base64() {
  local val="$1"
  # Minimum 8 chars filters short common words (true, User, ctfd, kind, etc.)
  [[ "${#val}" -ge 8 ]] || return 1
  [[ "$val" =~ ^[A-Za-z0-9+/]+={0,2}$ ]] || return 1
  (( ${#val} % 4 == 0 )) || return 1

  local decoded
  decoded=$(base64 --decode <<< "$val" 2>/dev/null) || return 1

  # Reject if >30% of decoded bytes are non-printable, non-whitespace (binary garbage)
  local total garbage
  total=$(printf '%s' "$decoded" | LC_ALL=C wc -c)
  (( total == 0 )) && return 1
  garbage=$(printf '%s' "$decoded" | LC_ALL=C tr -d '[:print:][:space:]' | LC_ALL=C wc -c)
  (( garbage * 10 <= total * 3 ))
}

ptitle() {
  local T="~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~"
  printf '\n%s %s %s\n' "$T" "$1" "$T"
}

pause4user() {
  echo ""
  read -r -p "[Press Return to continue]" line
  # Easteregg lets you issue commands immediately
  if [[ -n "$line" ]]; then
    _NEW_INPUT="$line"
  fi
}

follow_wait() {
  # Usage: follow_wait <thing> <command...>
  local thing="$1"
  shift
  echo "[Press Return to stop following: $thing]"
  "$@" &
  local pid="$!"
  read -r
  kill "$pid" 2>/dev/null
  wait "$pid" 2>/dev/null
  echo "! Stopped following: $thing"
}

get_actual_kind() {
  kubectl get "$2" -n "$1" -o json 2>/dev/null | jq -r '.kind'
}

confirm_action() {
    local object=${1:?Object (thing being acted on) required}
    local verb=${2:-removal}
    # shellcheck disable=SC2155
    local action_var="CONFIRM_ACTION_$(tr '[:lower:]' '[:upper:]' <<<"$verb")"

    # If the relevant CONFIRM_ACTION_* variable is already 'y', return immediately
    if [[ "${!action_var}" == "y" ]]; then
        return 0
    fi

    # Prompt for confirmation
    read -rp "Please confirm $verb of $object? (y)es|(n)o|(a)lways [yna]> " response
    case "$response" in
    [Yy])
        # Proceed just this once
        return 0
        ;;
    [Aa])
        # Set to confirm all future actions of this verb
        eval "${action_var}=y"
        return 0
        ;;
    *)
        echo "! $verb cancelled by user."
        return 1
        ;;
    esac
}

setup_ns() {

  local NS="$NAMESPACE"

  # If namespace passed as arg
  if [[ -n "$1" ]]; then
    if [[ "$1" == "all" ]]; then
      NS=""
    else
      NS="$1"
    fi

  #If not try using current dir as namespace name
  elif [[ -z "$NS" ]]; then
    NS="$(basename "$PWD")"

  fi

  if [[ -n "$NS" ]]; then
    if ! kubectl get namespace "$NS" >/dev/null 2>&1; then
      NS=""
    fi
  fi

  NAMESPACE="$NS"
  if [[ -n "$NAMESPACE" ]]; then
    echo "! Using namespace: $NAMESPACE"
  else
    echo "! Using namespace: <ALL>"
  fi
}

klist() {
  local res="$1"

  local KCNS=""
  if [[ -n "$NAMESPACE" ]]; then
    KCNS="--namespace=$NAMESPACE"
  else
    KCNS="--all-namespaces"
  fi

  local kc_exit
  KCGET="$(kubectl get "$res" "$KCNS" --show-kind 2>/dev/null)"
  kc_exit=$?
  [[ $kc_exit -eq 0 ]] || return $kc_exit

  ptitle "LIST $res"

  kobj=()
  local index=0
  while IFS= read -r line; do

    local NS="$NAMESPACE"
    if [[ "$line" =~ ^NAME|^NAMESPACE ]]; then
      kind=""
      echo "   $line"
      continue
    fi

    # shellcheck disable=SC2086
    set -- $line

    if [[ -z "$NAMESPACE" ]]; then
      NS="$1"; res="$2"
    else
      NS="$NAMESPACE"; res="$1"
    fi

    if [[ "$res" =~ ^([a-zA-Z0-9.-]+)/([^ ]+) ]]; then
      # Match kind/name
      kind="${BASH_REMATCH[1]}"
      name="${BASH_REMATCH[2]}"

      printf "%2d: %s\n" "$index" "$line"
      kobj[index]="$NS/$kind/$name"
      ((index++))
    else
      echo "$line"
    fi
  done <<<"$KCGET"

  return 0
}

input_loop(){
  echo "! Input just 'H' for help."

  while klist "$WHAT"; do

    # pause4user can queue up commands
    if [[ -n "$_NEW_INPUT" ]]; then
      input="$_NEW_INPUT"
      _NEW_INPUT=""
      echo ">> $input"
    else
      read -r -p "> " input
    fi

    # Trim leading/trailing whitespace
    input="${input#"${input%%[![:space:]]*}"}"
    input="${input%"${input##*[![:space:]]}"}"

    # repeat object list on empty input
    [[ -z "$input" ]] && continue

    if [[ "$input" =~ ^([a-zA-Z])([0-9]+)?(-([0-9]+))?$ ]]; then
      local letter="${BASH_REMATCH[1]}"
      local start="${BASH_REMATCH[2]}"
      local end="${BASH_REMATCH[4]}"

      [[ -z "$start" ]] && start=""  # no number given
      [[ -z "$end" ]] && end="$start" #no range given

      letter=$(tr '[:lower:]' '[:upper:]' <<<"$letter")

      if declare -f "do_$letter" > /dev/null; then
        if [[ -z "$start" ]]; then
          # No number: pass NS WHAT
          "do_$letter" "$NAMESPACE" "$WHAT"
        else
          local ns_objs=()
          local ns=""
          local ns_name=""
          local ns_objs=()
          for ((i=start; i<=end; i++)); do
            obj="${kobj[$i]}"
            if [[ -z "$obj" ]]; then
              echo "! Invalid object index: $i"
              continue
            fi
            ns="${obj%%/*}"
            if [[ "$ns" != "$ns_name" && "${#ns_objs[@]}" -gt 0 ]]; then
              "do_$letter" "$ns_name" "${ns_objs[@]}"
              ns_objs=()
            fi

            ns_name="$ns"
            ns_objs+=("${obj#*/}")
          done

          if [[ "${#ns_objs[@]}" -gt 0 ]]; then
            "do_$letter" "$ns_name" "${ns_objs[@]}"
          fi
        fi
        echo ""
      else
        echo "! No such function: '$letter'"
      fi

    else
      echo "! Invalid input: '$input'"
      do_H
    fi
  done
}

for cmd in $REQUIRED_TOOLS; do
    if ! command -v "$cmd" &>/dev/null; then
        echo "Needed tool '$cmd' not found, please install it."
        exit 1
    fi
done

WHAT=${1:-$ALLMORE}

setup_ns

input_loop
