#!/usr/bin/env bash

## Update nix installation and installed packages

case "$(uname -s)" in

  Darwin)
    sudo -i sh <<_EOM_
echo "--- Updating system nix install (macOS) ---"
nix-env --install --file '<nixpkgs>' --attr nix cacert -I nixpkgs=channel:nixpkgs-stable

echo "--- Restarting system nix daemon ---"
launchctl remove org.nixos.nix-daemon
launchctl load /Library/LaunchDaemons/org.nixos.nix-daemon.plist

echo "--- Collecting system garbage (removing old root generations and unlinked store paths) ---"
nix-collect-garbage -d
_EOM_
    ;;

  Linux)
    sudo -i sh <<_EOM_
echo "--- Updating system nix install (Linux) ---"
nix-env --install --file '<nixpkgs>' --attr nix cacert -I nixpkgs=channel:nixpkgs-stable

echo "--- Restarting system nix daemon ---"
systemctl restart nix-daemon

echo "--- Collecting system garbage (removing old root generations and unlinked store paths) ---"
nix-collect-garbage -d
_EOM_
    ;;

  *)
    echo "Unsupported OS: $(uname -s)" >&2
    exit 1
    ;;

esac

echo "--- Updating user nix channels ---"
nix-channel --update

echo "--- Upgrading user nix-env packages ---"
nix-env --upgrade

echo "--- Collecting garbage (removing old generations and unlinked store paths) ---"
nix-collect-garbage -d
